          <div class="card card-tilt" style="background: var(--c-bg);">
            <div style="display: flex; flex-direction: column; gap: var(--sp-md);">
              <div style="display: flex; align-items: flex-start; gap: var(--sp-sm);">
                <div style="width: 36px; height: 36px; background: var(--c-secondary); border-radius: var(--r-md); display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; font-family: var(--font-serif); font-size: 0.85rem; font-weight: 700;">1</div>
