            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--c-secondary)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
