                <div style="width: 36px; height: 36px; background: var(--c-secondary); border-radius: var(--r-md); display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; font-family: var(--font-serif); font-size: 0.85rem; font-weight: 700;">3</div>
